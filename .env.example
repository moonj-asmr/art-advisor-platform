# Backend — all optional; SQLite + local disk are the defaults
# DATABASE_URL=postgresql://postgres:postgres@db:5432/artadvisor
# ART_ADVISOR_DATA=/var/lib/artadvisor          # where the DB + extracted images live
# CORS_ORIGINS=http://localhost:5173

# Frontend — leave empty to use the Vite dev proxy
# VITE_API_URL=http://localhost:8000
